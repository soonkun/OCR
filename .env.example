# 이 파일을 복사해서 '.env' 라는 이름으로 저장하고, 따옴표 없이 실제 키를 넣으세요.
#   (Windows)  copy .env.example .env
#   (macOS)    cp .env.example .env
# 그다음 .env 를 열어 OPENAI_API_KEY 값을 본인 키로 바꾸세요.
#
# OpenAI API 키 (한국어+한자 → 한글 병기 LLM 보정에 사용)
OPENAI_API_KEY=sk-여기에_본인_키_붙여넣기

# (선택) 사용할 모델. 기본 gpt-4o
# OCR_LLM_MODEL=gpt-4o

# (선택) 한 번의 LLM 호출에 묶을 페이지 분량 (토큰 절약 조절)
# OCR_LLM_BATCH_CHARS=6000
# OCR_LLM_BATCH_MAX_PAGES=8
